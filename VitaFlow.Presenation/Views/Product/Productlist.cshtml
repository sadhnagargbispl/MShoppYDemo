@using Microsoft.AspNetCore.Http
@model VitaFlow.Domain.Entities.M_product
@{
    ViewData["Title"] = "Productlist";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // ⚠️ IMPORTANT: yahan wahi folder/base URL lagayein jahan product images actually store hoti hain.
    var imgBase = "https://d9franchise.bisplindia.in/ProductImages/";
    var defaultImg = "https://d9franchise.bisplindia.in/images/DefaultProduct.jpg";

    // ---- Dynamic max price for slider ----
    int maxPriceInt = 5000;
    if (Model.ProductsList != null && Model.ProductsList.Count() > 0)
    {
        double maxP = 0;
        foreach (var p in Model.ProductsList)
        {
            double v = 0;
            double.TryParse(Convert.ToString(p.Price), out v);
            if (v > maxP) maxP = v;
        }
        maxPriceInt = (int)Math.Max(1, Math.Ceiling(maxP));
    }
}

<script type="text/javascript">

    function QTYChange(sqty, prodid) {
        var Qty = $("#input_" + prodid).val();
        if (Qty == "") { return false; }
        if (parseInt(Qty) <= 0) {
            $("#input_" + prodid).val("1");
            return false;
        }
    }

    function Addtocart(ProdId) {
        debugger;
        var Qty = $("#input_" + ProdId).val();
        var availqty = $("#hndAvailstock_" + ProdId).val();
        if (Qty == "") {
            toastr.error("Please enter qty", 'Error', { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 5000, extendedTimeOut: 1000 });
            return false;
        }
        if (parseInt(Qty) <= 0) {
            toastr.error("Quntity greater than 0", 'Error', { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 5000, extendedTimeOut: 1000 });
            return false;
        }
        if (parseInt(Qty) > parseInt(availqty)) {
            var msg = 'Please enter a number less than or equal to ' + availqty;
            toastr.error(msg, 'Error', { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 5000, extendedTimeOut: 1000 });
            return false;
        }

        var ProdName = $("#hndprod_" + ProdId).val();
        var imagePath = $("#hndimg_" + ProdId).val();
        var BatchNo = $("#hndbatch_" + ProdId).val();
        $.ajax({
            type: "POST",
            url: "/Product/Addtocart",
            async: true,
            dataType: "Json",
            timeout: 900000,
            beforeSend: function () {
                $("#btn_" + ProdId).hide();
                $("#hidbtn_" + ProdId).show();
            },
            data: { ProdId: ProdId, ProdName: ProdName, imagePath: imagePath, Qty: Qty ,BatchNo,BatchNo},
            success: function (data) {
                if (data.msg == "1") {
                    $("#spncartcount").text(data.total);
                    var str = ProdName + " added to cart";
                    toastr.success(str, 'Success', { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 5000, extendedTimeOut: 1000 });
                }
                else {
                    var str = ProdName + " can not to add in cart";
                    toastr.error(str, 'Error', { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 5000, extendedTimeOut: 1000 });
                }
                $("#btn_" + ProdId).show();
                $("#hidbtn_" + ProdId).hide();
            },
            error: function (response) {
                console.log(response.responseText);
                $("#Submitbtn").prop('disabled', false);
                $("#btn_" + ProdId).show();
                $("#hidbtn_" + ProdId).hide();
            }
        });
    }

</script>

