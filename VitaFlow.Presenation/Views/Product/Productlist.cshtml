<div class="shop-page">

    <!-- Breadcrumb Start -->
    <div class="breadcrumb-header justify-content-between">
        <div class="left-content">
            <div>
                <h2 class="main-content-title tx-24 mg-b-1 mg-b-lg-1">Hi, @Convert.ToString(Context.Session.GetString("UserName"))!</h2>
                <p class="mg-b-0"> @Convert.ToString(Context.Session.GetString("PartyName"))</p>
            </div>
        </div>
    </div>
    <!-- Breadcrumb End -->

    <div class="row row-sm">

        <div class="col-lg-3 col-md-12">

            <div class="shop-filter-toggle d-lg-none">
                <button type="button" class="btn-filter-toggle" id="filterToggleBtn">
                    <i class="fa fa-sliders" aria-hidden="true"></i> Filters
                </button>
            </div>

            <div class="shop-filter-card" id="shopFilterCard">
                <div class="shop-filter-header">
                    <h6><i class="fa fa-filter" aria-hidden="true"></i> Filters</h6>
                    <button type="button" class="shop-filter-close d-lg-none" id="filterCloseBtn">&times;</button>
                </div>

                <!-- Search (product name se filter) -->
                <div class="shop-filter-section">
                    <h6 class="shop-filter-title">Search Product</h6>
                    <input type="text" id="productSearch" class="shop-filter-search" placeholder="Type product name..." autocomplete="off">
                </div>

                <!-- Price Range (dynamic) -->
                <div class="shop-filter-section">
                    <h6 class="shop-filter-title">Price Range</h6>
                    <input type="range" class="shop-filter-range" id="priceRange" min="0" max="@maxPriceInt" value="@maxPriceInt" step="1">
                    <div class="shop-filter-price-labels">
                        <span>&#8377; 0</span>
                        <span>Up to <strong id="priceRangeMaxLabel">&#8377; @maxPriceInt</strong></span>
                    </div>
                </div>

                <!-- Category (M_SubCatMaster ke hisaab se) -->
                <div class="shop-filter-section">
                    <h6 class="shop-filter-title">Category</h6>
                    <div class="shop-filter-catlist">
                        @if (Model.SubCategoriesList != null && Model.SubCategoriesList.Any())
                        {
                            foreach (var cat in Model.SubCategoriesList)
                            {
                                <div class="shop-filter-check">
                                    <label>
                                        <input type="checkbox" class="cat-filter" value="@cat.SubCatId"> @cat.SubCatName
                                    </label>
                                </div>
                            }
                        }
                        else
                        {
                            <p style="font-size:12px;color:#8893a8;margin:0;">No categories found.</p>
                        }
                    </div>
                </div>

                <!-- Availability (StockQTY ke hisaab se) -->
                <div class="shop-filter-section">
                    <h6 class="shop-filter-title">Availability</h6>
                    <div class="shop-filter-check"><label><input type="checkbox" id="chkInStock" checked> In Stock</label></div>
                    <div class="shop-filter-check"><label><input type="checkbox" id="chkOutStock"> Out of Stock</label></div>
                </div>

                <button type="button" class="btn-reset-filter" id="resetFilterBtn">Reset</button>
            </div>
        </div>

        <div class="shop-filter-backdrop" id="filterBackdrop"></div>

        <div class="col-lg-9 col-md-12">
            <div class="row row-sm row-deck" id="productGrid">
                @if (Model.ProductsList != null && Model.ProductsList.Count() > 0)
                {
                    foreach (var item in Model.ProductsList)
                    {
                        double mrpVal = 0; double priceVal = 0; double discPct = 0;
                        double.TryParse(Convert.ToString(item.MRP), out mrpVal);
                        double.TryParse(Convert.ToString(item.Price), out priceVal);
                        if (mrpVal > 0 && priceVal > 0 && mrpVal > priceVal)
                        {
                            discPct = Math.Round((mrpVal - priceVal) / mrpVal * 100);
                        }

                        double stockVal = Math.Round(Convert.ToDouble(item.StockQTY));

                        var rawImg = Convert.ToString(item.ImagePath);
                        var isValidImg = !string.IsNullOrWhiteSpace(rawImg)
                        && (rawImg.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
                        || rawImg.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                        || rawImg.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
                        || rawImg.EndsWith(".webp", StringComparison.OrdinalIgnoreCase)
                        || rawImg.EndsWith(".gif", StringComparison.OrdinalIgnoreCase));

                        var finalImg = !isValidImg
                        ? defaultImg
                        : (rawImg.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? rawImg : imgBase + rawImg);

                        <div class="col-12 col-sm-6 col-md-6 col-lg-4 col-xl-3 shop-product-item"
                             data-price="@priceVal"
                             data-stock="@stockVal"
                             data-subcat="@item.SubCatId"
                             data-name="@(Convert.ToString(item.ProductName).ToLower())">
                            <div class="card product-card pb-2">
                                <div class="product-card-media">
                                    @if (discPct > 0)
                                    {
                                        <span class="product-badge">@discPct% OFF</span>
                                    }
                                    @if (stockVal <= 0)
                                    {
                                        <span class="stock-badge out">Out of Stock</span>
                                    }
                                    <img src="@finalImg" class="card-img-top productimg" onerror="this.onerror=null;this.src='@defaultImg';" alt="Product Picture">
                                </div>
                                <input type="hidden" id="hndimg_@item.ProdId" value="@finalImg" />
                                <input type="hidden" id="hndprod_@item.ProdId" value="@item.ProductName" />
                                <input type="hidden" id="hndAvailstock_@item.ProdId" value="@stockVal" />
                                <input type="hidden" id="hndbatch_@item.ProdId" value="@item.BatchNo" />
                                <div class="card-body">
                                    <h5 class="title"> @item.ProductName </h5>
                                    <div class="price">
                                        <span class="price-current">&#8377; @item.Price</span>
                                        <del class="price-mrp">&#8377; @item.MRP</del>
                                        <span class="price-meta">BV : @item.BV &nbsp;|&nbsp; PV : @item.PV</span>
                                    </div>
                                    <div class="product-card-actions">
                                        <input type="number" name="number" onkeyup='QTYChange(@item.StockQTY,@item.ProdId)' id="input_@item.ProdId" class="form-control qty-input" min="1" value="1" required="required">

                                        <a href="javascript:void(0);" id="btn_@item.ProdId" onclick='Addtocart(@item.ProdId)' class="btn btn-primary btn-add-cart"> <i class="fa fa-shopping-bag" aria-hidden="true"></i> Add to Cart </a>

                                        <button class="btn btn-primary btn-add-cart" id="hidbtn_@item.ProdId" style="display:none;" type="button" disabled>
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="no-products-msg" id="noProductsMsg">
                <i class="fa fa-search" aria-hidden="true"></i>
                No products match your filters.
            </div>
        </div>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        /* ---------- Mobile filter drawer ---------- */
        var filterCard = document.getElementById('shopFilterCard');
        var backdrop = document.getElementById('filterBackdrop');
        var openBtn = document.getElementById('filterToggleBtn');
        var closeBtn = document.getElementById('filterCloseBtn');

        function openFilter() {
            filterCard.classList.add('show');
            backdrop.classList.add('show');
        }
        function closeFilter() {
            filterCard.classList.remove('show');
            backdrop.classList.remove('show');
        }
        if (openBtn) openBtn.addEventListener('click', openFilter);
        if (closeBtn) closeBtn.addEventListener('click', closeFilter);
        if (backdrop) backdrop.addEventListener('click', closeFilter);

        /* ---------- Product filtering (real data) ---------- */
        var MAX_PRICE = @maxPriceInt;
        var priceSlider = document.getElementById('priceRange');
        var priceLabel = document.getElementById('priceRangeMaxLabel');
        var searchBox = document.getElementById('productSearch');
        var inStockChk = document.getElementById('chkInStock');
        var outStockChk = document.getElementById('chkOutStock');
        var catChecks = document.querySelectorAll('.cat-filter');   // NEW
        var items = document.querySelectorAll('.shop-product-item');
        var noResults = document.getElementById('noProductsMsg');

        function applyFilters() {
            var maxVal = priceSlider ? parseFloat(priceSlider.value) : MAX_PRICE;
            var term = searchBox ? searchBox.value.trim().toLowerCase() : '';
            var wantIn = inStockChk ? inStockChk.checked : true;
            var wantOut = outStockChk ? outStockChk.checked : false;

            // agar dono unchecked hain to sab dikhao
            if (!wantIn && !wantOut) { wantIn = true; wantOut = true; }

            // checked categories collect karo
            var checkedCats = [];
            catChecks.forEach(function (c) { if (c.checked) checkedCats.push(c.value); });

            var visible = 0;
            items.forEach(function (el) {
                var price = parseFloat(el.getAttribute('data-price')) || 0;
                var stock = parseFloat(el.getAttribute('data-stock')) || 0;
                var name = el.getAttribute('data-name') || '';
                var subcat = el.getAttribute('data-subcat') || '';

                var okPrice = price <= maxVal;
                var isInStock = stock > 0;
                var okStock = (isInStock && wantIn) || (!isInStock && wantOut);
                var okName = term === '' || name.indexOf(term) !== -1;
                // koi category select nahi to sab dikhao, warna sirf matched
                var okCat = checkedCats.length === 0 || checkedCats.indexOf(subcat) !== -1;

                if (okPrice && okStock && okName && okCat) {
                    el.style.display = '';
                    visible++;
                } else {
                    el.style.display = 'none';
                }
            });

            if (noResults) noResults.style.display = (visible === 0) ? 'block' : 'none';
        }

        // Live filtering (turant apply)
        if (priceSlider) {
            priceSlider.addEventListener('input', function () {
                if (priceLabel) priceLabel.innerHTML = '&#8377; ' + Math.round(this.value);
                applyFilters();
            });
        }
        if (searchBox) searchBox.addEventListener('input', applyFilters);
        if (inStockChk) inStockChk.addEventListener('change', applyFilters);
        if (outStockChk) outStockChk.addEventListener('change', applyFilters);
        catChecks.forEach(function (c) { c.addEventListener('change', applyFilters); });   // NEW

        // Reset button (sab filters wapas default)
        var resetBtn = document.getElementById('resetFilterBtn');
        if (resetBtn) resetBtn.addEventListener('click', function () {
            if (searchBox) searchBox.value = '';
            if (priceSlider) priceSlider.value = MAX_PRICE;
            if (priceLabel) priceLabel.innerHTML = '&#8377; ' + MAX_PRICE;
            if (inStockChk) inStockChk.checked = true;
            if (outStockChk) outStockChk.checked = false;
            catChecks.forEach(function (c) { c.checked = false; });   // NEW
            applyFilters();
        });

        // Page load par ek baar chala do
        applyFilters();
    });
</script>