@model VitaFlow.Domain.Entities.User
@using Microsoft.AspNetCore.Http
@using System.Collections.Generic
@{
    ViewData["Title"] = "Home Page";
    int i = 1;
    var vfImgMap = ViewBag.ProductImageMap as Dictionary<string, string>;
}

<div class="vf-dashboard">
    <!-- Breadcrumb Start -->
    <div class="breadcrumb-header justify-content-between">
        <div class="left-content">
            <div>
                <h2 class="main-content-title tx-24 mg-b-1 mg-b-lg-1">Hi, @Convert.ToString(Context.Session.GetString("UserName"))!</h2>
                <p class="mg-b-0"> @Convert.ToString(Context.Session.GetString("PartyName"))</p>
            </div>
        </div>
    </div>
    <!-- Breadcrumb End -->
    <!-- Profile, Dashboard, Statistics Start -->
    <div class="row row-sm row-deck">
        <div class="col-md-12 col-lg-12 col-xl-12">
            <div class="card card-table-two">
                <div class="card-header bg-light mb-3">
                    <div class="d-flex justify-content-between">
                        <h4 class="card-title mb-1">@Convert.ToString(Context.Session.GetString("PartyName"))</h4>
                    </div>
                </div>

                <div class="row refill-stats-row">
                    <div class="col-md-6">
                        <div class="refill-stat-box">
                            <div class="refill-stat-box-top">
                                <div class="refill-stat-icon"><i class="fa fa-refresh" aria-hidden="true"></i></div>
                                <div class="refill-stat-info">
                                    <h6>Refill BV</h6>
                                    <span class="refill-stat-value">@Model.franchiseLimit.BVBalance</span>
                                </div>
                                <a href="~/Product/Productlist"><button class="btn btn-warning">BV LIMIT</button></a>
                            </div>
                            <div class="progress">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="width: @(Math.Round(Model.franchiseLimit.BVBalance, 0))%"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="refill-stat-box">
                            <div class="refill-stat-box-top">
                                <div class="refill-stat-icon"><i class="fa fa-line-chart" aria-hidden="true"></i></div>
                                <div class="refill-stat-info">
                                    <h6>Refill PV</h6>
                                    <span class="refill-stat-value">@Model.franchiseLimit.PVBalance</span>
                                </div>
                                <a href="~/Product/Productlist"><button class="btn btn-warning">PV LIMIT</button></a>
                            </div>
                            <div class="progress">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100" style='width: @(Math.Round(Model.franchiseLimit.PVBalance, 0))%'></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <!-- Profile, Dashboard, Statistics End -->
    <!-- Reward, Wallet, Membership Start -->
