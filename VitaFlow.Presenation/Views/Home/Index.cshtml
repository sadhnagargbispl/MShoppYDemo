<div class="col-md-12 col-lg-4 col-xl-4 col-sm-4">
    <div class="card card-dashboard-eight pb-2">
        <div class="card-header bg-light mb-2">
            <h6 class="card-title">TOP 10 PRODUCTS </h6>
        </div>

        <div class="list-group">
            @if (Model.TopsellingProduct != null && Model.TopsellingProduct.Count() > 0)
            {
                foreach (var item in Model.TopsellingProduct)
                {
                    <div class="list-group-item border-top-0">
                        <i class="flag-icon flag-icon-us flag-icon-squared"></i>
                        @{
                            string vfImg = string.IsNullOrWhiteSpace(item.ImagePath) ? "" : item.ImagePath;
                            var vfKey = System.Text.RegularExpressions.Regex.Replace((item.ProductName ?? "").ToUpper(), "[^A-Z0-9]", "");
                            if (string.IsNullOrWhiteSpace(vfImg) && vfImgMap != null && vfImgMap.ContainsKey(vfKey)) { vfImg = vfImgMap[vfKey]; }
                        }
                        <p> <img src="@vfImg" onerror="this.src='https://zadmin.zoewellness.co.in/images/DefaultProduct.jpg';" alt="Product Picture" class="rounded-" width="50"></p>
                        <p> <span>@item.ProductName</span> </p>
                    </div>


                }

            }
        </div>
    </div>
</div>
</div>

