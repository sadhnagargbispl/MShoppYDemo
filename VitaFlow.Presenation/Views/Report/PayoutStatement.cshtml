        </div>
        <div class="company-right">
            <div class="company-contact"><span>📞</span> <a href="tel:01120426612">0112 0426 6122</a></div>
            <div class="company-contact"><span>✉️</span> <a href="mailto:zoewellnessindia@gmail.com">zoewellnessindia@gmail.com</a></div>
            <div class="company-contact"><span>🌐</span> <a href="https://zoewellness.co.in/" target="_blank">zoewellness.co.in</a></div>
        </div>
    </div>

    <!-- MAIN WRAPPER -->
    <div class="wrapper">

        <!-- WELCOME MESSAGE -->
        <div class="welcome-card">
            <h2>🎉 Congratulations!</h2>
            <p>We feel pleasure to congratulate you on receiving your incentive cheque enclosed for the period from <strong>@Model.StatementPeriod</strong>, which comes out as a result of diligent efforts you and your team consultants have been putting in, for growing your Eazyways Business.</p>
            <p style="margin-top:10px">Sincerity and dedication towards your business will take you a long way towards achievements and prosperity. We at Eazyways are always willing to give you a supporting hand to all your efforts on achieving your goals any time. <strong>We Wish You Success!</strong></p>
        </div>

        <!-- SUMMARY CARDS -->
        @*         <div class="summary-row">
            <div class="sum-card">
                <span class="sum-icon">🛒</span>
                <div class="sum-label">Product Sale</div>
                <div class="sum-amount">₹1,20,035</div>
                <div class="sum-sub">Slab: 10% &nbsp;|&nbsp; Total: ₹12,003.50</div>
            </div>
            <div class="sum-card">
                <span class="sum-icon">📊</span>
                <div class="sum-label">PV Sale</div>
                <div class="sum-amount">₹638.13</div>
                <div class="sum-sub">Slab: 9% &nbsp;|&nbsp; Total: ₹5,743.17</div>
            </div>
            <div class="sum-card highlight">
                <span class="sum-icon">💰</span>
                <div class="sum-label">Total Incentive by Self Sale (A)</div>
                <div class="sum-amount">₹17,746.67</div>
                <div class="sum-sub">Product Sale + PV Sale</div>
            </div>
        </div> *@

        <!-- SELF SALE TABLE -->
        <div class="sec-title">📋 Self Sale Breakdown</div>
        <div class="card">
            <div class="card-head">📦 Self Sale — Incentive Calculation</div>
            <div style="overflow-x:auto">
                <table>
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Total Sale</th>
                            <th>Self Slab</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Product Sale <span style="color:var(--ink3);font-size:.75rem;font-weight:500">(a)</span></td>
                            <td>@Model.TotalBVVal</td>
                            <td>@Model.bV_Slab</td>
                            <td>@Model.self_Comm_BV</td>
                        </tr>
                        <tr>
                            <td>PV Sale <span style="color:var(--ink3);font-size:.75rem;font-weight:500">(b)</span></td>
                            <td>@Model.TotalPVVal</td>
                            <td>@Model.CommOnPv</td>
                            <td>@Model.selfIncomePv</td>
                        </tr>
                        <tr class="total-row">
                            <td colspan="3">TOTAL INCENTIVE BY SELF SALE (A) [a+b]</td>
                           @*  <td>@(Model.self_Comm_BV + (Model.selfIncomePv * Model.pvSlab))</td> *@
                            <td>@(Model.self_Comm_BV + Model.selfIncomePv)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- FRANCHISE NETWORK TABLE — Desktop -->
        <div class="sec-title">🏪 Franchise Network Incentive (B &amp; C)</div>
        <div class="card desktop-franchise">
            <div class="card-head">👥 Downline Franchisee Performance</div>
            <div class="franchise-table-wrap">
                <table class="franchise-tbl">
                    <thead>
                        <tr>
                            <th style="width:10%">ID No</th>
                            <th style="width:22%">Franchisee Name</th>
                            <th style="width:12%">Total BV Product (₹)</th>
                            <th style="width:8%">BV Slab (%)</th>
                            <th style="width:14%">Diff. BV Comm. (B) (₹)</th>
                            <th style="width:12%">Total PV Sale (₹)</th>
                            <th style="width:8%">PV Slab (%)</th>
                            <th style="width:14%">Diff. PV Comm. (C) (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DownlineFranchiseePerformance)
                        {
                            <tr>
                                <td><span class="tag-id">@item.FromPartyCode</span></td>
                                <td>@item.FranchiseeName</td>
                                <td>@item.Diff_Comm_BV</td>
                                <td>
                                    @if (item.Diff_Comm_Pv == 6)
                                    {
                                        <span class="slab-pill slab-6">@item.Diff_Comm_Pv</span>
                                    }
                                    else if (item.Diff_Comm_Pv == 4)
                                    {
                                        <span class="slab-pill slab-4">@item.Diff_Comm_Pv</span>
                                    }
                                    else if (item.Diff_Comm_Pv == 5)
                                    {
                                        <span class="slab-pill slab-5">@item.Diff_Comm_Pv</span>
                                    }
                                    else
                                    {
                                        <span class="slab-pill slab-6">@item.Diff_Comm_Pv</span>
                                    }
                                </td>
                                <td>
                                    @item.BvComm
                                    @{
                                        totalDiffBVComm = @totalDiffBVComm + @item.BvComm;
                                    }
                                </td>
                                <td>
                                    @if (item.Pv > 0)
                                    {
                                        @item.Pv
                                    }
                                    else
                                    {
                                        @hypstr
                                    }
                                </td>
                                <td>
                                    @if (item.Slab > 0)
                                    {
                                        @item.Slab
                                    }
                                    else
                                    {
                                        @hypstr
                                    }
                                </td>
                                <td>
                                    @if (item.PvComm > 0)
                                    {
                                        @item.PvComm
                                    }
                                    else
                                    {
                                        @hypstr
                                    }
                                    @{
                                        toralDiffPVComm = @toralDiffPVComm + @item.PvComm;
                                    }
                                </td>
                            </tr>
                        }

                        <tr class="total-row">
                            <td colspan="4">TOTAL</td>
                            <td>@totalDiffBVComm</td>
                            <td colspan="2"></td>
                            <td>@toralDiffPVComm</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- FRANCHISE NETWORK — Mobile Cards -->
        <div class="mobile-franchise">
            @foreach (var item in Model.DownlineFranchiseePerformance)
            {
                <div class="mfc">
                    <div class="mfc-header">
                        <div><div class="mfc-id">@item.FromPartyCode</div><div class="mfc-name">@item.FranchiseeName</div></div>
                        @if (item.Diff_Comm_Pv == 6)
                        {
                            <span class="slab-pill slab-6">@item.Diff_Comm_Pv</span>
                        }
                        else if (item.Diff_Comm_Pv == 4)
                        {
                            <span class="slab-pill slab-4">@item.Diff_Comm_Pv</span>
                        }
                        else if (item.Diff_Comm_Pv == 5)
                        {
                            <span class="slab-pill slab-5">@item.Diff_Comm_Pv</span>
                        }
                        else
                        {
                            <span class="slab-pill slab-6">@item.Diff_Comm_Pv</span>
                        }

                    </div>
                    <div class="mfc-rows">
                        <div class="mfc-row"><span class="mfc-row-label">Total BV (Product)</span><span class="mfc-row-val">₹@item.Diff_Comm_BV</span></div>
                        <div class="mfc-row"><span class="mfc-row-label">Diff. BV Commission (B)</span><span class="mfc-row-val blue">₹@item.BvComm</span></div>
                        @if (item.Pv > 0)
                        {
                            <div class="mfc-row"><span class="mfc-row-label">Total PV Sale</span><span class="mfc-row-val">₹@item.Pv</span></div>
                        }
                        @if (item.PvComm > 0)
                        {
                            <div class="mfc-row"><span class="mfc-row-label">Diff. PV Commission (C)</span><span class="mfc-row-val green">₹@item.PvComm</span></div>
                        }
                    </div>
                </div>
            }
            <!-- Mobile Total -->
            <div class="mfc" style="background:var(--blue-light);border-color:rgba(29,111,232,.2)">
                <div class="mfc-rows">
                    <div class="mfc-row"><span class="mfc-row-label" style="color:var(--blue);font-weight:800">TOTAL — Diff. BV Commission (B)</span><span class="mfc-row-val blue">₹@totalDiffBVComm *</span></div>
                    <div class="mfc-row"><span class="mfc-row-label" style="color:var(--green);font-weight:800">TOTAL — Diff. PV Commission (C)</span><span class="mfc-row-val green">₹@toralDiffPVComm</span></div>
                </div>
            </div>
        </div>

        <!-- INCENTIVE TOTALS -->
        <div class="sec-title">💡 Incentive Summary</div>
        <div class="totals-grid">
            <div class="total-card">
                <h4>Total Incentive by Self Sale (A)</h4>
                @* <div class="val">₹@Model.Self_Comm_BV</div> *@
                <div class="val">₹@(Model.self_Comm_BV + Model.selfIncomePv)</div>
            </div>
            <div class="total-card blue-card">
                <h4>Diff. BV Commission (B)</h4>
                <div class="val">₹@totalDiffBVComm</div>
            </div>
            <div class="total-card green-card">
                <h4>Diff. PV Commission (C)</h4>
                <div class="val">₹@toralDiffPVComm</div>
            </div>
            <div class="total-card" style="background:var(--ink);border:none">
                <h4 style="color:rgba(255,255,255,.55)">Total Incentive (A + B + C)</h4>
                <div class="val" style="color:white">₹@(Model.Self_Comm_BV + Model.selfIncomePv + totalDiffBVComm + toralDiffPVComm)</div>
            </div>
        </div>

        <!-- DEDUCTION NOTE -->
        <div class="deduction-box">
            <h4>⚠️ Please Note — Deductions Applied</h4>
            <p>Deduction of <strong>@AdminChargeper%</strong> towards the Eazyways IBCW Welfare Society, to support orphan child program, IBC family support &amp; other society's welfare activities, and <strong>@AdminChargeper% admin deduction</strong> have been applied.</p>
            <p style="margin-top:8px"><strong>Admin Charge: @AdminChargeper% = ₹@Model.AdminCharge</strong></p>
        </div>

        <!-- FINAL CHEQUE AMOUNT -->
        <div class="cheque-card">
            <div class="clabel">🎉 Your Incentive Cheque Amount</div>
            <div class="cval">₹@Model.ChequeAmount</div>
            <div class="csub">Period: @Model.StatementPeriod &nbsp;|&nbsp; Franchisee: @Model.GroupCode-@Model.partycode</div>
        </div>

        <!-- FINAL NOTE -->
        <div style="background:white;border:1.5px solid var(--line);border-radius:14px;padding:18px 20px;font-size:.84rem;color:var(--ink3);line-height:1.7">
            <strong style="color:var(--ink);font-family:&#39;Plus Jakarta Sans&#39;,sans-serif">Grand Total: ₹@Model.ChequeAmount</strong><br>
            This statement is computer generated. For any queries, please contact your Eazyways support team directly.
        </div>

    </div><!-- /wrapper -->
    <!-- FOOTER -->
    <div class="page-footer">
        Generated by <strong>Eazyways Business Network</strong> &nbsp;|&nbsp; Franchisee: @Model.GroupCode-@Model.partycode &nbsp;@* |&nbsp; Period: Feb 2026 *@
    </div>



</body>
</html>