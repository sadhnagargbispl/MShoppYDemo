<!-- Components Start -->
<div class="row">
    <div class="col-lg-12 col-xl-12 col-md-12 col-sm-12">
        <div class="card  box-shadow-0">
            <div class="card-header">
                Sales Report > Product Wise
            </div>
            <form id="distributorForm">
                <div class="card-body pt-0 bg-white">
                    <div class="row">
                        @Html.HiddenFor(m => m.PartyCode, new { id = "PartyCode", name = "PartyCode" })
                        @Html.HiddenFor(m => m.InvoiceType, new { id = "hiddenInvoiceType", name = "hiddenInvoiceType" })
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>From Date</label>
                                @Html.TextBoxFor(m => m.StartDate, new { name = "StartDate", id = "StartDate", tabindex = "1", @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>To Date</label>
                                @Html.TextBoxFor(m => m.EndDate, new { name = "EndDate", id = "EndDate", @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-md-2" id="IsProductDiv">
                            <div class="form-group mt-4">
                                <input type="checkbox" id="IsDateFilter" name="IsDateFilter" class="flat" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-8">
                            <div class="form-group">
                                <label> Category</label>
                                @Html.TextBoxFor(m => m.CustCode, new { name = "CategoryName", id = "CategoryName", @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group mt-4">
                                <input type="checkbox" id="IsCategory" name="IsCategory" class="flat" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-8">
                            <div class="form-group">
                                <label> Product</label>
                                @Html.TextBoxFor(m => m.CustCode, new { name = "ProductName", id = "ProductName", @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group mt-4">
                                <input type="checkbox" id="IsProduct" name="IsProduct" class="flat" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <input type="button" class="btn btn-primary" id="btnExport" name="btnExport" value="Download Excel" />
                    <div class="btn-group fa-pull-right">
                        <button type="button" data-ReportType="Summary" name="btnShowReport" class="btn btn-primary mr-2 btnShowReport">Show Report</button>
                        <button type="button" data-ReportType="Detail" name="btnShowReport" class="btn btn-primary btnShowReport">Show Detail Report</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-12 col-xl-12 col-md-12 col-sm-12">
        <div class="card-table-two bg-white">
            <div class="table-responsive country-table bg-white">
                <table id="grid" class="table text-center table-striped table-bordered mb-0 text-sm-nowrap text-lg-nowrap text-xl-nowrap">
                </table>
            </div>
        </div>
    </div>
</div>