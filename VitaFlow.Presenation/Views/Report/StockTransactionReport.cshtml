<!-- Components Start -->
<div class="row">
    <div class="col-lg-12 col-xl-12 col-md-12 col-sm-12">
        <div class="card  box-shadow-0">
            <div class="card-header">
                <h4 class="card-title mb-1">
                    Stock Transaction Report
                </h4>
            </div>
            <form class="form-horizontal">
                <div class="card-body pt-0 bg-white">
                    <div class="row">
                        @Html.HiddenFor(m => m.PartyCode, new { id = "PartyCode", name = "PartyCode" })
                        @Html.HiddenFor(m => m.GroupId, new { id = "GroupId", name = "GroupId" })
                        @Html.HiddenFor(m => m.CategoryCode, new { id = "CategoryCode", name = "CategoryCode" })
                        @Html.HiddenFor(m => m.ProductCode, new { id = "ProductCode", name = "ProductCode" })
                        @Html.HiddenFor(m => m.StateCode, new { id = "hiddenStateCode" })

                        <div class="col-md-4">
                            <div class="form-group">
                                <label>From Date</label>
                                @Html.TextBoxFor(m => m.StartDate, new { name = "StartDate", id = "StartDate", tabindex = "1", @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>To Date</label>
                                @Html.TextBoxFor(m => m.EndDate, new { name = "EndDate", id = "EndDate", @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-md-2" id="IsDateDiv">
                            <div class="form-group mt-4">
                                <input type="checkbox" id="IsDateFilter" name="IsDateFilter" class="flat" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label>Category</label>
                            <select name="Category" id="Category" class="form-control">
                                <option value="All">All</option>
                                @foreach (var obj in Model.CategoryList)
                                {
                                    <option value="@obj.CategoryId">@obj.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 form-group">
                            <label>
                                Product
                            </label>
                            @Html.TextBoxFor(m => m.ProductName, new { name = "ProductName", id = "ProductName", @class = "form-control" })
                        </div>
                        <div class="col-md-2" id="IsProductDiv">
                            <div class="form-group mt-4">
                                <input type="checkbox" id="IsProduct" name="IsProduct" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <input type="button" class="btn btn-primary" id="btnExport" name="btnExport" value="Download Excel" />
                    <div class="btn-group fa-pull-right">
                        <button type="button" id="Summary" data-type="B" class="btn btn-primary mr-2 ">Product Wise Summary</button>
                        <button type="button" id="Invoice" data-type="D" class="btn btn-primary mr-2 ">Invoice Wise Summary</button>
                        <button type="button" id="Detail" data-type="P" class="btn btn-primary mr-2 ">Detail</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-12 col-xl-12 col-md-12 col-sm-12">
        <div class="card-table-two bg-white">
            <div class="table-responsive country-table bg-white">
                <table id="grid" class="table text-center table-striped table-bordered mb-0 text-sm-nowrap text-lg-nowrap text-xl-nowrap">
                </table>
            </div>
        </div>
        <table id="gridExport" style="display:none"></table>
    </div>
</div>


