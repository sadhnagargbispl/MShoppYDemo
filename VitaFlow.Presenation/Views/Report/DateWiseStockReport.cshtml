    </div>
</div>
<!-- Breadcrumb End -->
<!-- Components Start -->
<div class="row">
    <div class="col-lg-12 col-xl-12 col-md-12 col-sm-12">
        <div class="card  box-shadow-0">
            <div class="card-header">
                Date wise Stock Summary
            </div>
            <form id="distributorForm">
                <div class="card-body pt-0 bg-white">
                    <div class="row">
                        <input type="hidden" id="PartyCode" value="@Context.Session.GetString("PartyCode")" />
                        <input type="hidden" asp-for="ProductCode" id="ProductCode" value="" />
                        <input type="hidden" asp-for="CategoryCode" id="CategoryCode" value="" />
                        <div class="col-md-4">
                            <label>Product</label>
                            <div class="input-group mb-3">
                                <input type="text" asp-for="ProductName" id="ProductName" class="form-control">
                                <div class="input-group-append">
                                    <div class="input-group-text">
                                        <input type="checkbox" id="IsProduct" name="IsProduct">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label>Date</label>
                            <input type="text" asp-for="StartDate" id="StartDate" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label>To</label>
                            <input type="text" asp-for="EndDate" id="EndDate" class="form-control">
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <input type="button" class="btn btn-primary" id="btnExport" name="btnExport" value="Download Excel" />
                    <div class="btn-group fa-pull-right">
                        <button type="button" id="CurrentStock" class="btn btn-primary mr-2">Total Stock</button>
                        @if (IsSoldByHo == true)
                        {
                            <button type="button" id="btnOverAllReport" class="btn btn-primary">All Shoppe Stock</button>
                        }

                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-12 col-xl-12 col-md-12 col-sm-12 mt-5">
        <div class="card  box-shadow-0">
            <div class="card-header">
                <ul class="list-group list-group-horizontal fa-pull-right">
                    <li class="list-group-item">Op.Stock Value : <span id="opval">0</span></li>
                    <li class="list-group-item">Cls.Stock Value :  <span id="clsval">0</span></li>
                </ul>
            </div>
            <div class="card-body bg-white">
                <div class="table-responsive">
                    <table class="table table-bordered" id="grid"></table>
                </div>
            </div>
        </div>
        <table id="gridExport" style="display:none"></table>
    </div>
</div>
<!-- Components End -->
