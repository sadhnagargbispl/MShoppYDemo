        function SaveBill() {

            var ListObjStr = JSON.stringify(ProductGrid);
            $("#ListObjHidden").val(ListObjStr);
            formdata = new FormData($("#distributorForm")[0]);
            $.ajax({
                url: '@Url.Action("SaveDistributorBill", "Transaction")',
                type: 'POST',
                data: formdata,
                processData: false,
                contentType: false,
                dataType: "json",
                success: function (objResponse) {
                    debugger;
                    $("#hidbtn").hide();
                    $("#SaveDistributorForm").show();
                    $("#SaveDistributorForm").attr("disabled", false);
                    console.log("objResponse", objResponse)
                    if (objResponse != null) {

                        if (objResponse.responseStatus == "OK") {

                            toastr.success(objResponse.responseMessage, 'success', {
                                closeButton: true,
                                progressBar: true,
                                positionClass: 'toast-top-right',
                                timeOut: 5000, // 5 seconds
                                extendedTimeOut: 1000 // 1 second longer than timeOut
                            });
                            setTimeout(function () {
                                window.location.href = '/Transaction/DistributorBill';
                            }, 1000);
                        }
                        else {
                            toastr.error(objResponse.responseMessage, 'Warning', {
                                closeButton: true,
                                progressBar: true,
                                positionClass: 'toast-top-right',
                                timeOut: 5000, // 5 seconds
                                extendedTimeOut: 1000 // 1 second longer than timeOut
                            });

                        }
                    }
                },
                error: function (xhr, data) {
                    //  return false;
                    console.log(xhr);
                    console.log("Error:", data);
                }
            });
        }
