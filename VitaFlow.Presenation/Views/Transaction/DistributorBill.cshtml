@model VitaFlow.Domain.Entities.DistributorBillModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "DistributorBill";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string WBalance = ViewBag.WBalance;
    bool IsAdministrator = Convert.ToBoolean(Context.Session.GetString("IsSoldByHo"));
    string CVCaption = ViewBag.CVCaption;
    string BVCaption = ViewBag.BVCaption;
    string PVCaption = ViewBag.PVCaption;
    string RPCaption = ViewBag.RPCaption;
    string BarcodeCaption = ViewBag.BarcodeCaption;
}

<!-- Breadcrumb Start -->
<div class="breadcrumb-header justify-content-between">
    <div class="left-content">
        <div>
            <h2 class="main-content-title tx-24 mg-b-1 mg-b-lg-1">Hi, @Convert.ToString(Context.Session.GetString("UserName"))!</h2>
            <p class="mg-b-0"> @Convert.ToString(Context.Session.GetString("PartyName"))</p>
        </div>
    </div>
</div>
<!-- Breadcrumb End -->

<div class="row row-sm row-deck">

    <div class="col-md-12 col-lg-12 col-xl-12 col-sm-12">
        <div class="card card-dashboard-eight pb-2 bg-light prodcutbox">
            <h5> Bill  Details </h5>
            <hr>
            <form id="distributorForm" method="post" name="distributorForm">
                <div class="row">
                    <div class="col-lg-12 ">
                        @*  <h5 style="color:red;"> Press Shift+n to focus out of Product Section </h5>
                        <hr> *@

                        @Html.Hidden("IsAdd", "", new { name = "isAdd", id = "isAdd" })
                        @Html.HiddenFor(m => m.objCustomer.FormNo, new { name = "FormNo", id = "FormNo" })
                        @Html.HiddenFor(m => m.objProductListStr, new { name = "ListObjHidden", id = "ListObjHidden" })
                        @Html.HiddenFor(m => m.objCustomer.IsBillOnMrp, new { id = "IsBillOnMrp" })
                        @Html.HiddenFor(m => m.objCustomer.MinBillAmt, new { id = "MinBillAmt" })
                        @Html.HiddenFor(m => m.objCustomer.MinRepurch, new { id = "MinRepurch" })
                        @Html.HiddenFor(m => m.objCustomer.IsFirstBill, new { id = "FirstBill" })
                        @Html.HiddenFor(m => m.offerId, new { name = "offerId", id = "offerId" })
                        @Html.HiddenFor(m => m.objCustomer.StateCode, new { id = "StateCode" })
                        @Html.HiddenFor(m => m.objCustomer.IsActive, new { id = "IsActive" })
                        @Html.HiddenFor(m => m.objCustomer.Doj, new { name = "Doj", id = "Doj" })
                        @Html.HiddenFor(m => m.objCustomer.UpgradeDate, new { id = "UpgradeDate" })
                        @Html.Hidden("SpclOffer", "", new { name = "SpclOffer", id = "SpclOffer" })
                        @Html.Hidden("OfferType", "0", new { name = "OfferType", id = "OfferType" })
                        @Html.HiddenFor(m => m.objCustomer.MaxBV, new { id = "MaxBV", name = "MaxBV" })
                        @Html.HiddenFor(m => m.objProduct.isFixedQty, new { name = "isFixedQty", id = "isFixedQty" })
                        @Html.HiddenFor(m => m.objProduct.FixedQty, new { name = "FixedQty", id = "FixedQty" })
                        <div class="row mb-3">
                            <label class="col-sm-2 col-form-label">Invoice Type</label>
                            <div class="col-sm-6">
                                @Html.HiddenFor(m => m.objCustomer.SelectedInvoiceType, new { id = "hiddenSelectedInvoiceType", name = "hiddenSelectedInvoiceType" })
                                <select asp-for="SelectedInvoiceType" id="SelectedInvoiceType" onchange="Disablepaymode()" class="form-control" tabindex="0" name="SelectedInvoiceType">
                                    <option value="">--Select Type--</option>
                                    <option value="PV">PV</option>
                                    <option value="BV">BV</option>
                                </select>
                            </div>
                           
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-2 col-form-label Paymodedivlabel" style="display:none;">Payment Method</label>
                            <div class="col-sm-4" id="Paymodediv" style="display:none;">
                                <select id="PaymentMethodDrop" class="form-control" onchange="DispalyPaymode()" tabindex="0" name="PaymentMethodDrop">
                                    <option value="Cash">Use Cash</option>
                                   @*  <option value="FPorCou">Use FP or Voucher</option> *@
                                </select>
                            </div>
                            <label class="col-sm-2 col-form-label" style="display:none;" id="passworddivlabel">Password</label>
                            <div class="col-sm-2" id="passworddiv" style="display:none;">
                                <input type="password" id="userpassw" class="form-control" value="" />
                                <input type="hidden" id="passwvarify" class="form-control" value="false" />
                            </div>
                            <div class="col-sm-1" id="passworddivbutton" style="display:none;">
                                <button type="button" id="Varify" class="btn btn-primary">Verify</button>
                            </div>

                        </div>
                        <div class="row mb-3">
                            <label for="IdNo" class="col-sm-2 col-form-label">IdNo</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.objCustomer.IdNo, new
                                {
                                    id = "IdNo",
                                    @class = "form-control",
                                    autocomplete = "off"
                                })

                                @*  @Html.TextBoxFor(m => m.objCustomer.IdNo, new { name = "IdNo", id = "IdNo", @maxlength = "50", @class = "form-control" }) *@
                            </div>
                            <label for="OfferList" class="col-sm-2 col-form-label" style="display:none;"> Choose Offer</label>
                            <div class="col-sm-4" style="display:none;">
                                @Html.DropDownListFor(m => m.NewofferId, ViewBag.OfferList as IEnumerable<SelectListItem>, new { tabindex = "0", @class = "form-control", @name = "OfferList", @id = "OfferList" })
                            </div>
                            <label class="col-sm-2 col-form-label">Name</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.objCustomer.Name, new { name = "Name", id = "Name", @maxlength = "50", @class = "form-control", @readonly = "readonly" })
                                <label class="control-label" for="category-name" id="IDType_" style="color:green;display:none;"></label>
                            </div>

                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-2 col-form-label">City[State]</label>
                            <div class="col-sm-4">
                                @Html.TextAreaFor(m => m.objCustomer.Address, new { name = "Address", id = "Address", @class = "form-control", @readonly = "readonly" })
                            </div>

                            <label class="col-sm-2 col-form-label">District</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.objCustomer.DistrictName, new { name = "DistrictName", id = "DistrictName", @class = "form-control", @readonly = "readonly" })
                            </div>
                        </div>
                        @if (IsAdministrator)
                        {
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Tax Type</label>
                                <div class="col-sm-4">
                                    <select name="TaxType" id="TaxType" class="form-control">
                                        <option value="CS">CGST&SGST</option>
                                        <option value="I">IGST</option>
                                    </select>
                                </div>
                            </div>
                        }

                        <hr>
                        <h3 class="mb-5"> Products Details  </h3>
                        <div id="DivHideShowID">

                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label"> Product  </label>
                                <div class="col-sm-1 col-4">
                                    <select class="form-control" id="prdselectiontype">
                                        <option value="P"> P </option>
                                        <option value="B"> B </option>
                                    </select>
                                </div>
                                <div class="col-sm-3 col-8">
                                    @Html.TextBoxFor(m => m.objProduct.ProductName, new { tabindex = "0", name = "ProductName", id = "ProductName", @class = "form-control" })
                                    @Html.HiddenFor(m => m.objProduct.ProductName, new { id = "ProductHidden" })
                                </div>

                                <label class="col-sm-2 col-form-label">Bar Code</label>
                                <div class="col-sm-4">
                                    @Html.TextBoxFor(m => m.objProduct.Barcode, new { tabindex = "0", name = "Barcode", id = "Barcode", @class = "form-control" })
                                    @Html.HiddenFor(m => m.objProduct.Barcode, new { id = "BarcodeHidden" })
                                    <select tabindex="0" name="BarcodeList" id="BarcodeList" style="display:none;width:100%" class="form-control">
                                        <option value="0">--Select barcode</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">

                                <label class="col-sm-2 col-form-label">Batch Code</label>
                                <div class="col-sm-4">
                                    <select tabindex="0" name="BatchcodeList" id="BatchcodeList" style="width:100%" class="form-control">
                                        <option value="0">--Select BatchCode</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label"> Qty  </label>
                                <div class="col-sm-4 mb-3">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            @Html.TextBoxFor(m => m.objProduct.Quantity, new { name = "Quantity", maxlength = "10", tabindex = "0", id = "Quantity", @class = "form-control" })
                                        </div>
                                        <div class="col-sm-6">
                                            @Html.TextBoxFor(m => m.objProduct.StockAvailable, new { name = "StockAvailable", id = "StockAvailable", @class = "form-control", @readonly = "readonly" })
                                        </div>
                                    </div>

                                </div>

                                <label class="col-sm-2 col-form-label">DP</label>
                                <div class="col-sm-4">
                                    @Html.TextBoxFor(m => m.objProduct.DP, new { name = "DP", id = "DP", @class = "form-control", @readonly = "readonly" })
                                </div>
                            </div>
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Free Qty</label>
                                <div class="col-sm-4">
                                    @Html.Hidden("BuyFreeQty", "0", new { name = "BuyFreeQty", id = "BuyFreeQty" })
                                    @Html.TextBoxFor(m => m.objProduct.FreeQty, new { name = "FreeQty", maxlength = "10", tabindex = "0", id = "FreeQty", @class = "form-control onlyDecimalValues", @readonly = "readonly" })
                                </div>
                                <label class="col-sm-2 col-form-label"> Disc.  </label>
                                <div class="col-sm-4">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            @Html.TextBoxFor(m => m.objProduct.DiscPer, new { name = "DiscPer", id = "DiscPer", @readonly = "readonly", @class = "form-control" })
                                        </div>
                                        <div class="col-sm-6">
                                            @Html.TextBoxFor(m => m.objProduct.DiscAmt, new { name = "DiscAmt", id = "DiscAmt", @class = "form-control", @readonly = "readonly" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Amount</label>
                                <div class="col-sm-4">
                                    @Html.TextBoxFor(m => m.objProduct.Amount, new { name = "Amount", id = "Amount", @class = "form-control", @readonly = "readonly" })
                                </div>

                                <label class="col-sm-2 col-form-label"> Tax  </label>
                                <div class="col-sm-4">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            @Html.TextBoxFor(m => m.objProduct.TaxPer, new { name = "TaxPer", id = "TaxPer", @class = "form-control", @readonly = "readonly" })
                                        </div>
                                        <div class="col-sm-6">
                                            @Html.TextBoxFor(m => m.objProduct.TaxAmt, new { name = "TaxAmt", id = "TaxAmt", @class = "form-control", @readonly = "readonly" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label"> Total Amount  </label>
                                <div class="col-sm-4">
                                    @Html.TextBoxFor(m => m.objProduct.TotalAmount, new { name = "TotalAmount", id = "TotalAmount", @class = "form-control", @readonly = "readonly" })
                                </div>
                            </div>
                            <hr>
                            <button type="button" id="AddRecordInGrid" class="btn btn-primary mt-4"> <i class="fa fa-plus" aria-hidden="true"></i> Add Product</button>
                            <button type="button" id="ClearDetails" class="btn btn-info mt-4"> <i class="fa fa-minus" aria-hidden="true"></i> Clear Product</button>
                            <div class="clearfix"> </div>
                            <div class="table-responsive">
                                <table class="table table-bordered mt-5" id="grid"></table>
                            </div>
                            <div class="row mb-3 mt-3">
                                <label class="col-sm-2 col-form-label"> Delivery Place </label>
                                <div class="col-sm-8">
                                    @Html.TextBoxFor(m => m.objProduct.DeliveryPlace, new { name = "DeliveryPlace", id = "DeliveryPlace", @class = "form-control" })
                                </div>
                                <div class="col-sm-2">
                                    <button type="button" id="paymodebtn" class="btn btn-primary" data-toggle="collapse" data-target="#collapseExample" aria-expanded="false" aria-controls="collapseExample">  Pay Mode </button>
                                    @Html.HiddenFor(m => m.objProduct.PayDetails.PayMode, new { @name = "hiddenPaymode", @id = "hiddenPaymode" })
                                </div>
                            </div>
                            <div class="clearfix"> </div>
                            <!-- Collapse Data Start -->
                            <div class="row">
                                <div class="collapse w-100" id="collapseExample">
                                    <div class="card card-body cardbg">
                                        <div class="row">
                                            <div class="col-sm-4">Payment Mode :</div>
                                            <div class="col-sm-4"></div>
                                            <div class="col-sm-4"><button type="button" id="paymodeclose" style="float:right;" class="btn btn-primary">Close</button></div>
                                        </div>
                                        <hr>
                                        <div class="row mb-3" style="display:none;">
                                            <div class="col-sm-2">
                                                <div class="form-check mt-2">
                                                    <input class="form-check-input" type="radio" name="exampleRadios" id="exampleRadios1" value="option1">
                                                    <label class="form-check-label" for="exampleRadios1">
                                                        By Card(CC)
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AmountByCard, new { @class = "form-control", @name = "AmountByCard", @id = "AmountByCard", @disabled = "disabled", tabindex = "0" })
                                            </div>

                                            <div class="col-sm-1">
                                                <label class="col-form-label"> Card No.    </label>
                                            </div>

                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.CardNo, new { tabindex = "0", @class = "form-control", @name = "CardNo", @id = "CardNo", @maxlength = "16", @disabled = "disabled" })
                                            </div>

                                            <div class="col-sm-1">
                                                <label class="col-form-label"> </label>
                                            </div>

                                            <div class="col-sm-2">
                                                @Html.DropDownListFor(m => m.objProduct.PayDetails.CardType, ViewBag.CardTypes as IEnumerable<SelectListItem>, new { tabindex = "0", @class = "form-control", @name = "CardType", @id = "CardType", @disabled = "disabled" })
                                            </div>
                                        </div>


                                        <div class="row mb-3">
                                            <div class="col-sm-2">
                                                <div class="form-check mt-2">
                                                    @* <input asp-for="objProduct.PayDetails.IsV" class="form-check-input" type="checkbox" name="objProduct.PayDetails.IsV" id="IsV" value="V"> *@
                                                    @Html.CheckBoxFor(m => m.objProduct.PayDetails.IsV, new { @name = "IsV", id = "IsV", @class = "form-check-input bvoffer" })
                                                    <label class="form-check-label" for="IsV">
                                                        FP Voucher
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-sm-2" style="display:none;">

                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.FpVoucher, new { @class = "form-control", @placeholder = "Voucher Code", @name = "FpVoucher", @id = "FpVoucher", @disabled = "disabled" })
                                            </div>
                                            <div class="col-sm-2">
                                                <label class="col-form-label">FPV Balance  </label>
                                            </div>
                                            <div class="col-sm-2">
                                                <input type="text" id="vamt" class="form-control" value="0" readonly />
                                            </div>
                                            <div class="col-sm-2">
                                                <label class="col-form-label">Ad. Amount  </label>
                                            </div>

                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AmountByVoucher, new { @class = "form-control", @placeholder = "Amount", @name = "AmountByVoucher", @id = "AmountByVoucher", @readonly = "readonly" })
                                                <input type="hidden" value="0" id="hidfpamt" />
                                            </div>

                                        </div>

                                        <div class="row mb-3" style="display:none;">
                                            <div class="col-sm-2">
                                                <div class="form-check mt-2">
                                                    @* <input asp-for="objProduct.PayDetails.IsCU" class="form-check-input" type="checkbox" name="objProduct.PayDetails.IsCU" id="IsCU" value="Cu"> *@

                                                    @Html.CheckBoxFor(m => m.objProduct.PayDetails.IsCU, new { @name = "IsCU", id = "IsCU", @class = "form-check-input bvoffer" })
                                                    <label class="form-check-label" for="IsCU">
                                                        Coupon
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-sm-2">

                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.Coupon, new { @class = "form-control", @placeholder = "Coupon Code", @name = "Coupon", @id = "Coupon", @disabled = "disabled" })
                                            </div>
                                            <div class="col-sm-2">
                                                <label class="col-form-label">Coupon Amount  </label>
                                            </div>
                                            <div class="col-sm-2">
                                                <input type="text" id="camt" class="form-control" value="0" readonly />
                                            </div>
                                            <div class="col-sm-2">
                                                <label class="col-form-label">Ad. Amount  </label>
                                            </div>

                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AmountbyCoupon, new { @class = "form-control", @placeholder = "Amount", @name = "AmountbyCoupon", @id = "AmountbyCoupon", @maxlength = "16", @readonly = "readonly" })
                                                <input type="hidden" value="0" id="hidcamt" />
                                            </div>

                                        </div>
                                        @*  <div class="row mb-3">
                                        <div class="col-sm-2">
                                            <label class="col-form-label">Password  </label>
                                        </div>
                                        <div class="col-sm-2">
                                            <input type="password" id="userpassw" disabled class="form-control" value="" />
                                            <input type="hidden" id="passwvarify" class="form-control" value="false" /> 
                                        </div>
                                        <div class="col-sm-1">
                                            <button type="button" id="Varify" disabled class="btn btn-primary">Varify</button> 
                                        </div>
                                    </div> *@
                                        <div class="row mb-3">
                                            <div class="col-sm-2">
                                                <div class="form-check mt-2">
                                                    @Html.CheckBoxFor(m => m.objProduct.PayDetails.IsW, new { @class = "form-check-input", @name = "W", id = "W" })
                                                    <label class="form-check-label" for="W">
                                                        By Wallet(W)
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AmountByWallet, new { @class = "form-control onlyNumeric", @name = "AmountByWallet", @id = "AmountByWallet", @disabled = "disabled" })
                                            </div>
                                            <div class="col-sm-1">
                                                <label class="col-form-label"> Avail Bal.  </label>
                                            </div>
                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AvailBal, new { @class = "form-control", @name = "AvailBal", @id = "AvailBal", @readonly = "readonly" })
                                            </div>
                                            <div class="col-sm-1">
                                                <label for="inputEmail3" class="col-form-label">Rem Bal. </label>
                                            </div>
                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.RemBal, new { @class = "form-control", @name = "RemBal", @id = "RemBal", @readonly = "readonly" })
                                            </div>
                                            @* <div class="col-sm-1">
                                            <button type="button" id="BillCalculation" class="btn btn-primary">Calculate</button>
                                        </div> *@
                                        </div>
                                        <div class="row mb-3">
                                            <div class="col-sm-2">
                                                <div class="form-check mt-2">
                                                    @Html.CheckBoxFor(m => m.objProduct.PayDetails.IsBD, new { @name = "BD", id = "BD", @class = "form-check-input" })
                                                    <label class="form-check-label" for="W">
                                                        By Bank
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-sm-2">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AmountByBD, new { @class = "form-control", @name = "AmountByBD", @id = "AmountByBD", @disabled = "disabled" })
                                            </div>
                                            <div class="col-sm-3">
                                                @Html.DropDownListFor(m => m.objProduct.PayDetails.BankCode,
                                                ViewBag.BankNames as IEnumerable<SelectListItem>,
                                                                                                new { @class = "form-control", id = "BankCode", disabled = "disabled" })
                                                @Html.HiddenFor(m => m.objProduct.PayDetails.BDBankName)
                                            </div>
                                            <!-- Account No -->
                                            <div class="col-sm-2">

                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.AccNo,
                                                                                                new { @class = "form-control", id = "AccNo", disabled = "disabled", @placeholder = "Acc No." })
                                            </div>
                                            <!-- IFSC -->
                                            <div class="col-sm-3">
                                                @Html.TextBoxFor(m => m.objProduct.PayDetails.IFSCCode,
                                                                                                new { @class = "form-control", id = "IFSCCode", disabled = "disabled", @placeholder = "IFSC Code" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Collapse Data End -->

                            </div>
                        </div>
                    </div>

                </div>

                <div class="clearfix"> </div>

                <hr>
                <div class="row mb-3">

                    <label class="col-sm-2 col-form-label"> Total Qty </label>
                    <div class="col-sm-2">
                        @Html.TextBoxFor(m => m.objProduct.TotalQty, new { name = "TotalQty", id = "TotalQty", @class = "form-control", @readonly = "readonly" })
                    </div>
                    <label class="col-sm-2 col-form-label"> Total Ad. @BVCaption  </label>
                    <div class="col-sm-2">
                        <input type="text" name="TotalAdBV" id="TotalAdBV" class="form-control" readonly="readonly" value="0" />
                    </div>

                    <label class="col-sm-2 col-form-label"> Total @BVCaption  </label>
                    <div class="col-sm-2">
                        @Html.TextBoxFor(m => m.objProduct.TotalBV, new { name = "TotalBV", id = "TotalBV", @class = "form-control", @readonly = "readonly" })
                    </div>


                </div>

                <div class="row mb-3">
                    <label class="col-sm-2 col-form-label"> Total @PVCaption  </label>
                    <div class="col-sm-2">
                        @Html.TextBoxFor(m => m.objProduct.TotalPV, new { name = "TotalPV", id = "TotalPV", @class = "form-control", @readonly = "readonly" })
                    </div>

                    <label class="col-sm-2 col-form-label"> Amount  </label>
                    <div class="col-sm-2">
                        @Html.TextBoxFor(m => m.objProduct.TotalTotalAmount, new { name = "TotalTotalAmount", id = "TotalTotalAmount", @class = "form-control", @readonly = "readonly" })
                    </div>
                    <label class="col-sm-2 col-form-label"> Trade Disc.(-)  </label>
                    <div class="col-sm-2">
                        @Html.TextBoxFor(m => m.objProduct.TotalDiscount, new { name = "TotalDisc", id = "TotalDisc", @class = "form-control", @readonly = "readonly" })
                    </div>


                </div>

