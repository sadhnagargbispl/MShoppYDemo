        function DoCalculation(offerproduct) {
            //  var ProductGrid = [{ "SNo": "", "Code": "", "ProductName": "", "MRP": "", "DP": "", "Rate": "", "Barcode": "", "RP": "", "BV": "", "CV": "", "PV": "", "Qty": "", "RPValue": "", "BVValue": "", "CVValue": "", "PVValue": "", "CommsnPer": "", "CommsnAmt": "", "DiscPer": "", "DiscAmt": "", "Amount": "", "TaxType": "", "TaxPer": "", "TaxAmt": "", "TotalAmount": "" }];
            if (ProductArray != null && ProductArray != undefined) {
                var Quantity = parseFloat(($("#Quantity").val() != "" || $("#Quantity").val() != null) ? $("#Quantity").val() : 0);
                var FreeQ = parseFloat(($("#FreeQty").val() != "" || $("#FreeQty").val() != null) ? $("#FreeQty").val() : 0);
                var dpValue;
                var CommissionLessDp;
                ProductArray.Qty = Quantity;

                //   if (Quantity <= ProductArray.AvailStock || ProductArray.AvailStock<=0) {
                if (IsCommissionAdd == 1) {
                    var Commssn = ProductArray.DP * ProductArray.CommsnPer / 100;
                    dpValue = ProductArray.DP - Commssn;
                    CommissionLessDp = dpValue;
                    ProductArray.CommssnAmt = Commssn * Quantity;
                }
                else {
                    dpValue = ProductArray.DP;
                }


                //to be calculated if value for this in config is "Y"
    @*var IsDiscountCalculated = '@Model.objConfigDetails.C_AllowDiscount';
                var IsDiscountForAllCust = '@Model.objConfigDetails.C_DiscForAllCust';
                var ToCalculateDiscount = true;
                if (IsDiscountForAllCust == "Y") {
                ToCalculateDiscount = true;
                }
                else {
                if (IsRegisteredCustomerCheck) {
                ToCalculateDiscount = true;
                }
                else {
                ToCalculateDiscount = false;
                }
                }*@
                         //if (IsDiscountCalculated == "Y" && ToCalculateDiscount == true) {
                var DiscPer = ProductArray.DiscPer;
                var DiscAmt = ProductArray.DiscAmt;

                /*if (IsQty == "D") {
                    dpValue = CommissionLessDp;
                    DiscPer = parseInt($("#DiscPer").val());
                }*/

                if (IsDiscountAdd == 1) {
                    if (DiscAmt == 0 && DiscPer != 0) {
                        var Discount = dpValue * DiscPer / 100;
                        dpValue = dpValue - Discount;
                        ProductArray.DiscAmt = Discount * Quantity;
                    }
                    else if (DiscPer == 0 && DiscAmt != 0) {
                        var Discount = DiscAmt;
                        dpValue = dpValue - Discount;
                        ProductArray.DiscAmt = Discount;
                    }
                    else {
                        ProductArray.DiscAmt = 0;
                    }
                }
                else {
                    ProductArray.DiscAmt = 0;
                }
                //}
                //else {
                //    ProductArray.DiscAmt = 0;
                //}

                var type = parseInt($("#OfferType").val());
                dpValue = ProductArray.OriDP;
                ProductArray.DP = ProductArray.OriDP;
                $("#DP").val(ProductArray.DP);
                var QtyWithoutFree = 0;
                if (!isNaN(type) && (type == 1 || type == 3 || type == 9999)) {
                    var fQ = parseInt($("#BuyFreeQty").val());
                    if (fQ != NaN && fQ != 0) {
                        //dpValue = ProductArray.OriDP;
                        //var per = parseFloat(fQ / Quantity).toFixed(2);
                        //ProductArray.DiscPer = per * 100;
                        //ProductArray.BuyFreeQty = fQ;
                        //QtyWithoutFree = Quantity - fQ;
                        //ProductArray.DiscAmt = (dpValue - (dpValue * per)) * Quantity;
                        //dpValue = dpValue * per;
                        //ProductArray.DP = dpValue;
                        //$("#DP").val(dpValue);
                        //alert("in-" + fQ);
                        dpValue = ProductArray.OriDP;
                        QtyWithoutFree = Quantity - fQ;
                        var tdp = dpValue * QtyWithoutFree;
                        ProductArray.DP = tdp / Quantity;
                        ProductArray.BuyFreeQty = fQ;
                        dpValue = tdp / Quantity;
                        ProductArray.DiscAmt = dpValue * fQ;
                        $("#DP").val((ProductArray.DP).toFixed(2));
                    }
                    else {
                        debugger;
                        ProductArray.DiscPer = 0;
                        QtyWithoutFree = Quantity;
                        ProductArray.DiscAmt = 0;
                        ProductArray.BuyFreeQty = 0;
                    }
                }
                else {
                    ProductArray.BuyFreeQty = 0;
                    QtyWithoutFree = Quantity;
                    ProductArray.DiscPer = 0;
                    ProductArray.DiscAmt = 0;
                }
                debugger;

                ProductArray.Rate = dpValue * 100 / (100 + parseFloat(ProductArray.TaxPer));
                ProductArray.Amount = dpValue * Quantity * 100 / (100 + (parseFloat(ProductArray.TaxPer)));
                ProductArray.TaxAmt = (dpValue * Quantity) - ProductArray.Amount;
                var temp = (ProductArray.TaxAmt.toFixed(2)).toString();
                var lastNum = parseInt(temp[temp.length - 1]);
                console.log("lastNum", lastNum);
                console.log("ProductArray.TaxAmt", ProductArray.TaxAmt);
                console.log("ProductArray.Amount", ProductArray.Amount);
                if ((parseInt(lastNum) % 2) != 0) {
                    $("#OldTaxAmount").val(parseFloat(ProductArray.TaxAmt));
                    ProductArray.Amount = parseFloat(ProductArray.Amount) + 0.01;
                    ProductArray.TaxAmt = parseFloat(ProductArray.TaxAmt) - 0.01;
                }
                if (Quantity == 1)//Added on 07Feb19
                    ProductArray.Rate = ProductArray.Amount;

                ProductArray.RPValue = ProductArray.RP * QtyWithoutFree;
                ProductArray.CVValue = ProductArray.CV * QtyWithoutFree;
                ProductArray.BVValue = ProductArray.BV * QtyWithoutFree;
                ProductArray.PVValue = ProductArray.PV * QtyWithoutFree;
                ProductArray.TotalWeight = ProductArray.Weight * Quantity;
                ProductArray.FreeQty = FreeQ;

                if (offerproduct) {
                    if (type != 2) {
                        ProductArray.TotalAmt = 0;
                        ProductArray.Amount = 0;
                    }
                    else {
                        ProductArray.TotalAmt = (dpValue * Quantity);
                    }
                    // ProductArray.TaxAmt = 0; Cmnted on 07Feb19
                    ProductArray.DiscAmt = 0;
                    ProductArray.RPValue = 0;
                    ProductArray.CVValue = 0;
                    ProductArray.BVValue = 0;
                    ProductArray.PVValue = 0;
                    ProductArray.ProductTye = "F";
                }
                else if (offerproduct == false || type == 2) {
                    ProductArray.TotalAmt = (dpValue * Quantity);
                    ProductArray.ProductTye = "P";
                }
                $("#DiscPer").val((ProductArray.DiscPer).toFixed(2));
                $("#DiscAmt").val((ProductArray.DiscAmt).toFixed(2));
                $("#TaxAmt").val((ProductArray.TaxAmt).toFixed(2));
                $("#Amount").val((ProductArray.Amount).toFixed(2));
                $("#TotalAmount").val((ProductArray.TotalAmt).toFixed(2));
                $("#TotalWeight").val((ProductArray.TotalWeight).toFixed(2));

            }
        }
