                        //response(ItemList);
                    },
                    minLength: 1,
                    scroll: true,
                    select: function (event, ui) {
                        $("#ProductName").val(ui.item.label);
                        var productName = ui.item.label;
                        var index = OfferItemList.indexOf(productName);
                        var offerType = $("#OfferType").val();
                        if (SelectedOfferID != "0" && (offerType == "2" || offerType == "3")) {
                            if (index == -1) {
                                GetProductInfo("P", ui.item.label, false, 0);
                                $("#Quantity").focus();
                            }
                            else {
                                toastr.warning("Sorry you can't select offer products.", 'Warning', {
                                    closeButton: true,
                                    progressBar: true,
                                    positionClass: 'toast-top-right',
                                    timeOut: 5000, // 5 seconds
                                    extendedTimeOut: 1000 // 1 second longer than timeOut
                                });
                            }
                        }
                        else {
                            GetProductInfo("P", ui.item.label, false, 0);
                            $("#Quantity").focus();
                        }
                        return false;
                    },

