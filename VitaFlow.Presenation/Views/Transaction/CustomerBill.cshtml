                                IsDiscountAdd = objResult[0].isDiscountAdd;
                                ProductSearchList = objResult;
                                $("#ProductNameList").empty();
                                //$("#BarcodeList").empty();
                                $("#BatchcodeList").empty();
                                AvailableBatchcodeList = [];
                                AvailableProductList = [{}];
                                if (isProductSearch == "P") {
                                    if (isProductSearch == "P") {
                                        $("#ProductName").val(objResult[0].productName);
                                        $("#ProductHidden").val(objResult[0].productName);
                                        var f = true;
                                        if (AvailableBarcodeList != null && AvailableBarcodeList.length > 0) {
                                            AvailableBarcodeList = $.grep(AvailableBarcodeList, function (e) {
                                                return e.ProductName != objResult[0].productName;
                                            });
                                        }
                                        for (var i = 0; i < objResult.length; i++) {
                                            if (f == true) {
                                                f = false;
                                                $("#BarcodeHidden").val(objResult[i].barcode);
                                                $("#Barcode").val(objResult[i].barcode);
                                            }

                                            AvailableBarcodeList.push({ "ProductName": objResult[i].productName, "BarCode": objResult[i].barcode });

                                        }
                                        fillBarcodeList(objResult[0].productName);

                                    }

                                }
                                if (isProductSearch == "B") {
                                    $("#Barcode").val(objResult[0].barcode);
                                    $("#BarcodeHidden").val(objResult[0].barcode);
                                    var f = true;
                                    for (var i = 0; i < objResult.length; i++) {
                                        if (f == true) {
                                            f = false;
                                            $("#ProductHidden").val(objResult[i].productName);
                                        }
                                        AvailableProductList = AvailableProductList.splice(1);
                                        AvailableProductList.push({ "ProdCode": objResult[i].prodCode, "ProductName": objResult[i].productName });
                                        $("#ProductNameList").append("<option value=" + objResult[i].prodCode + ">" + objResult[i].productName + "</option>");
                                    }

                                }
                                if (AvailableBatchcodeList != null && AvailableBatchcodeList.length > 0) {
                                    AvailableBatchcodeList = $.grep(AvailableBatchcodeList, function (e) {
                                        return e.ProductName != objResult[0].productName;
                                    });
                                }
                                var k = true;
                                debugger;
                                for (var i = 0; i < objResult[0].batchdetail.length; i++) {
                                    if (k == true) {
                                        k = false;
                                        //$("#BarcodeHidden").val(objResult[i].Barcode);
                                    }
                                    AvailableBatchcodeList.push({ "BatchCode": objResult[0].batchdetail[i].batchNo,
                                    "ProductName": objResult[0].batchdetail[i].productName, });

                                }
                                fillBatchcodeList(objResult[0].ProductName);
                                fillProductValues(objResult[0]);
                            }
                            else {
                                
                                 toastr.error("No Product Found!", 'Error', {
                        closeButton: true,
                        progressBar: true,
                        positionClass: 'toast-top-right',
                        timeOut: 8000, // 8 seconds
                        extendedTimeOut: 2000 // 2 second longer than timeOut
                     });
                                //$("#ProductName").val("");

                                ClearProductdetailsWithoutChangingValues();
                            }
