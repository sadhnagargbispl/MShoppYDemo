        function getAllBarcode() {
            $.ajax({
                url: '/Transaction/GetAllBarcode',
                dataType: 'JSON',
                method: 'GET',
                //data: { 'LedgerName': '' },
                success: function (data) {
                    console.log("data:", data);
                    //response(data);
                    BarcodeList = [];
                    if (data != null) {
                        var i = 0;
                        for (i = 0; i < data.length; i++) {
                            //console.log("data[i]", data[i]);
                            BarcodeList.push(data[i]);
                        }

                    }
                },
                error: function (error) {
                    console.log(error);
                }
            });
        }
