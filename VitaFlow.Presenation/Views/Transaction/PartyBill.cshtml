    function GetAllParty() {
         
        $.ajax({
            url: '/Transaction/GetAllPartywithBal',
            dataType: 'JSON',
            method: 'GET',
            success: function (data) {
                debugger;
                console.log("data:", data);
                //response(data);
                debugger;
                FullPartyList = data;
                PartyList = [];
                if (data != null) {
                    var i = 0;
                    for (i = 0; i < data.length; i++) {
                        //console.log("data[i]", data[i]);
                        if (data[i].groupId != 5) {
                            PartyList.push(data[i].partyName);
                        }
                    }

                    if (data.length >= 1) {
                        var LoginPartyCode = '@CurrentPartyCode';
                        if (LoginPartyCode == data[0].PartyCode && data[0].groupId != 5) {
                            $("#PartyName").val(data[0].partyName);
                            $("#PartyCode").val(data[0].partyCode);
                            $("#SelectedPartyStateCode").val(data[0].stateCode);
                            $("#DeliveryPlace").val(data[0].address1)


                        }
                    }
                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    }

    function openBill(billNo, soldBy, billType) {
        var url = '@Url.Action("InvoicePrint", "Transaction", new { Pm = "-1" })';
        var encodedparameters = billNo;
        //console.log("encodedparameters", encodedparameters);
        //encodedparameters="uid=testuser&pwd=test123456&Id=84503&Name=tes&Email=abc@xyz.com&MobileNo=9829898298&Address=Bhl";
        var EncryptedB64Url = window.btoa(encodedparameters);
        console.log("EncryptedB64Url", EncryptedB64Url);
        url = url.replace("-1", EncryptedB64Url);

        console.log("url", url);
        var win = window.open(url, '_blank');
        //win.focus();
    }
    function GetWallTypeBalance(Vtype) {
         var WType = "";
        WType = Vtype == "P" ? "W" : "Z";
        if (Vtype == "P") {

            $("#hiddenSelectedInvoiceType").val("PV");
        }
        if (Vtype == "B") {

            $("#hiddenSelectedInvoiceType").val("BV");
        }
        var PartyCode = $("#PartyCode").val();
        $.ajax({
            url: '/Transaction/GetWalletTypeBalance',
            dataType: 'JSON',
            method: 'GET',
            data: { Shoppe: PartyCode, Vtype: WType },
            success: function (data) {
                if (Vtype == "P") {
                    $("#SPNPVBalance").text(data);
                    $("#SPNBVBalance").text('');

                }
                if (Vtype == "B") {
                    $("#SPNPVBalance").text('');
                    $("#SPNBVBalance").text(data);

                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    }

