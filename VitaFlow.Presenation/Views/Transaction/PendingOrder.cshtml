            dataType: "json",
            success: function (objResult) {
                if (objResult != null) {
                    debugger;
                    var i = 0;
                    OrderProductGrid = [{}];
                    for (i = 0; i < objResult.length; i++) {
                        if (objResult[i].batchNo != "" || objResult[i].batchNo != null) {
                            var Quantity = parseFloat((objResult[i].dispQty != "" || objResult[i].dispQty != null) ? objResult[i].dispQty : 0);
                            var dpValue;
                            var CommissionLessDp;
                            var AvailStock = 0;
                            console.log("Quantity", Quantity);
                            var DP = objResult[i].dp;
                            console.log("objResult[i].AvailStock in do calculation", objResult[i].stockAvailable);
                            if (Quantity <= objResult[i].stockAvailable || objResult[i].stockAvailable <= 0) {
                                if (IsCommissionAdd == 1) {
                                    var Commssn = objResult[i].dp * objResult[i].commsnPer / 100;
                                    dpValue = objResult[i].dp - Commssn;
                                    CommissionLessDp = dpValue;
                                    objResult[i].CommssnAmt = Commssn * Quantity;
                                }
                                else {
                                    dpValue = objResult[i].dp;
                                }
                                var DiscPer = objResult[i].discPer;
                                var DiscAmt = objResult[i].discAmt;
                                if (IsDiscountAdd == 1) {
                                    if (DiscAmt == 0 && DiscPer != 0) {
                                        var Discount = dpValue * DiscPer / 100;
                                        dpValue = dpValue - Discount;
                                        objResult[i].discAmt = Discount * Quantity;
