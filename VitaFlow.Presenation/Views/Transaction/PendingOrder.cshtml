    function AutoCalculateTotals() {
        debugger;
        console.log("ProductGrid", ProductGrid);
        if (ProductGrid != null) {
            if (ProductGrid[0].SNo == "" || ProductGrid[0].SNo == null || ProductGrid[0].SNo == undefined)
