            //var CashAmount = 0;
            var TotalBV = 0;
            var TotalCV = 0;
            var TotalPV = 0;
            TotalQty = 0;
            var TotalDiscountPer = 0;
            var TotalCommsonAmt = 0;
            TotalSumNetAmount = 0;
            TotalTaxtAmt = 0;
            TotalDisc = 0;
