           function validatePayment(mainWallet, promoWallet, billAmount, mainBalance, promoBalance) {
               debugger;
        // Convert values to numbers
        mainWallet = Number(mainWallet) || 0;
        promoWallet = Number(promoWallet) || 0;
        billAmount = Number(billAmount);
        mainBalance = Number(mainBalance);
        promoBalance = Number(promoBalance);

        // Check available balance for each wallet
        if (promoWallet > promoBalance) {
            
            toastr.error("Promo wallet amount exceeds available promo balance.", 'Error', {
                    closeButton: true,
                    progressBar: true,
                    positionClass: 'toast-top-right',
                    timeOut: 5000, // 5 seconds
                    extendedTimeOut: 1000 // 1 second longer than timeOut
                   });
            return false;
        }

        if (mainWallet > mainBalance) {
            
            toastr.error("BV wallet purchase amount exceeds available main balance.", 'Error', {
                    closeButton: true,
                    progressBar: true,
                    positionClass: 'toast-top-right',
                    timeOut: 5000, // 5 seconds
                    extendedTimeOut: 1000 // 1 second longer than timeOut
                   });
            return false;
        }

        // Check total required amount
        if ((mainWallet + promoWallet) !== billAmount) {
            
            toastr.error("Total wallet amount must equal bill amount.", 'Error', {
                    closeButton: true,
                    progressBar: true,
                    positionClass: 'toast-top-right',
                    timeOut: 5000, // 5 seconds
                    extendedTimeOut: 1000 // 1 second longer than timeOut
                   });
            return false;
        }

        // Case 1: Full payment from promo wallet
        if (promoWallet === billAmount) {
            return true;
        }

        // Case 2: Using both wallets
        if (promoWallet > 0 && mainWallet > 0) {
            return true;
        }

        // Case 3: Promo insufficient → main wallet mandatory
        if (promoWallet < billAmount && mainWallet > 0) {
            return true;
        }

        // otherwise invalid
        
        toastr.error("BV wallet purchase wallet is required when promo wallet does not cover full bill.", 'Error', {
                    closeButton: true,
                    progressBar: true,
                    positionClass: 'toast-top-right',
                    timeOut: 5000, // 5 seconds
                    extendedTimeOut: 1000 // 1 second longer than timeOut
                   });
        return false;
    }



