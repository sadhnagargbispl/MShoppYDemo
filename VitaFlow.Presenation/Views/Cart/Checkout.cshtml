    function GetCity()
    {
        var citycode = $("#citycode");
        var Statecode = $("#statecode").val();
        $.ajax({
            type: "POST",
            url: '/Cart/GetCity',
            datatype: "json",
            async: true,
            data: { Statecode: Statecode },
            success: function (data) {
                debugger;
                citycode.empty();
                $.each(data, function (index, value) {
                    debugger;
                    citycode.append("<option value='" + value.cityCode + "'>" + value.cityName + "</option>")
                });
            }
        });
    }
    function validateEmail(email)
    {
        var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        return emailRegex.test(email);
    }
    function Checkpackage()
    {
        $.ajax({
            type: "POST",
            url: '/Cart/Checkpackage',
            datatype: "json",
            async: true,
            success: function (data) {
                debugger;
                if (data.status == "0") {
                    window.location.href = "/Cart/PackageSelection";
                }
                else if (data.status == "1") {
                    toastr.warning("Your cart amount is less than selected package", 'Success', {
                        closeButton: false,
                        progressBar: true,
                        positionClass: 'toast-top-right',
                        timeOut: 5000, // 5 seconds
                        extendedTimeOut: 3000 // 1 second longer than timeOut
                    });
                }
                else {
                   return true;

                }

            }
        });
    }
        function loadBVBalance()
          {
        $.ajax({
            type: "POST",
