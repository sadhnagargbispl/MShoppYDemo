        $('#promobaladjust').on('keypress', function (e) {
        var charCode = (e.which) ? e.which : e.keyCode;

        // Allow: backspace, delete, tab, escape, enter
        if ($.inArray(charCode, [8, 9, 27, 13, 46]) !== -1) {
            return true;
        }

        // Allow: one dot (.)
        if (charCode == 46) {
            if ($(this).val().indexOf('.') === -1) {
                return true;
            } else {
                return false; // block second dot
            }
        }

        // Allow: 0-9
        if (charCode >= 48 && charCode <= 57) {
            return true;
        }

        // Block everything else
        return false;
    });

