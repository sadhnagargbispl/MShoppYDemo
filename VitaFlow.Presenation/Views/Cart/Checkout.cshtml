        text-align: center;
        width: 100%;
        background: linear-gradient(90deg, #2e5fe6 0%, #00b8a9 100%);
        color: #fff;
        font-weight: 600;
        letter-spacing: .4px;
        text-transform: uppercase;
        font-size: 13.5px;
        padding: 14px;
        border-radius: 10px;
        border: none;
        box-shadow: 0 12px 25px rgba(46, 95, 230, .25);
        transition: transform .2s ease, box-shadow .2s ease;
        text-decoration: none;
    }

    .premium-checkout-page .btn-pay-now:hover {
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 16px 30px rgba(0, 184, 169, .32);
    }

    @@media (max-width: 991px) {
        .premium-checkout-page .checkout-summary-card { margin-top: 0; }
    }
</style>

<div class="container-fluid premium-checkout-page">
<!-- Breadcrumb Start -->
<div class="breadcrumb-header justify-content-between">
    <div class="left-content">
        <div>
            <h2 class="main-content-title tx-24 mg-b-1 mg-b-lg-1"> Product Checkout</h2>
            <p class="mg-b-0"> @Convert.ToString(Context.Session.GetString("PartyName"))</p>
        </div>
    </div>
</div>
<!-- Breadcrumb End -->

<div class="row row-sm row-deck">

    <div class="col-md-12 col-lg-12 col-xl-7 col-sm-12">
        <div class="checkout-card">
            <div class="checkout-card-header">
                <h5><i class="fa fa-user" aria-hidden="true"></i> Your Billing Details</h5>
            </div>
            <div class="row">
                <div class="col-md-6 form-group-checkout">
                    <label>Business Name</label>
                    <input type="text" asp-for="BusinessName" name="BusinessName" id="BusinessName" required="" class="form-control" placeholder="Enter Business Name">
                </div>
                <div class="col-md-6 form-group-checkout">
                    <label>Customer Name</label>
                    <input type="text" required="" asp-for="CustomerName" name="CustomerName" id="CustomerName" class="form-control" placeholder="Enter Customer Name">
                </div>
                <div class="col-md-12 form-group-checkout">
                    <label>Address 1</label>
                    <input type="text" required="" asp-for="Address1" name="Address1" id="Address1" class="form-control" placeholder="Enter Address 1">
                </div>
                <div class="col-md-12 form-group-checkout">
                    <label>Address 2</label>
                    <input type="text" required="" asp-for="Address2" name="Address2" id="Address2" class="form-control" placeholder="Enter Address 2">
                </div>
                <div class="col-md-6 form-group-checkout">
                    <label>State</label>
                    <select class="form-control" asp-for="StateCode" id="statecode" onchange="GetCity()">
                        @foreach (var item in Model.Statelist)
                        {
                            <option value="@item.StateCode">@item.StateName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 form-group-checkout">
                    <label>City</label>
                    <select class="form-control" asp-for="CityCode" id="citycode">
                        @foreach (var item in Model.CityList)
                        {
                            <option value="@item.CityCode">@item.CityName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 form-group-checkout">
                    <label>Pin Code</label>
                    <input type="text" required="" asp-for="Pincode" name="Pincode" id="pincode" class="form-control" placeholder="Enter Pin Code">
                </div>
                <div class="col-md-6 form-group-checkout">
                    <label>Mobile No.</label>
                    <input type="text" required="" asp-for="MobileNo" name="MobileNo" onkeypress="return isNumberKey(event);" id="mobile" class="form-control" placeholder="Enter Mobile No.">
                </div>
                <div class="col-md-12 form-group-checkout">
                    <label>Email ID</label>
                    <input type="text" required="" asp-for="Email" name="Email" id="email" class="form-control" placeholder="Enter Email ID">
                </div>
            </div>
            <br>


        </div>
    </div>


    <div class="col-md-12 col-lg-12 col-xl-5 col-sm-12">
        <div class="checkout-summary-card">
            <div class="checkout-summary-header">
                <h5>Order Summary</h5>
                <span class="badge-count">@(Model.CartList != null ? Model.CartList.Count() : 0) Items</span>
            </div>
            <div class="checkout-summary-items">
                @foreach (var item in Model.CartList)
                {
                    <div class="checkout-summary-item">
                        <img src="@item.imagePath" onerror="this.src='https://zadmin.zoewellness.co.in/images/DefaultProduct.jpg';" alt="Product Picture">
                        <div class="checkout-summary-item-info">
                            <p class="name">@item.ProdName</p>
                            <span class="qty">Qty: @item.qty</span>
                        </div>
                        <span class="price">Rs. @(item.Price * item.qty)</span>
                    </div>
                }
            </div>
            <div class="checkout-summary-totals">
                <div class="summary-row"><span>Subtotal</span><span>Rs. @Model.TotalAmont</span></div>
                <div class="summary-row total"><span>Total Payable Amount</span><span>Rs. @Model.TotalAmont</span></div>
                <input type="hidden" id="totalamount" class="form-control" value="@Model.TotalAmont " />

                <div class="summary-row summary-method-row">
                    <span>Order Method</span>
                    <select class="form-control summary-method-select" id="ordermethod">
                        <option value="0">Select Order Method</option>
                        <option value="PV">PV</option>
                        <option value="BV">BV</option>
                    </select>
                </div>

                <div class="summary-row" id="ordermethodselectwallet" style="display:none;">
                    <span>BV Wallet Balance</span>
                    <span><span id="walbal1">0</span></span>
                </div>

                <div class="summary-row" id="ordermethodselectPVwallet" style="display:none;">
                    <span>PV Wallet Balance</span>
                    <span><span id="PVwalbal1">0</span></span>
                </div>

                <div class="summary-wallet-block" id="trPVPurchaseBalanace" style="display:none;">
                    <p class="summary-wallet-title">PV Wallet Purchase Balanace</p>
                    <div class="row">
                        <div class="col-md-5 form-group">
                            <label>Aval. Bal.</label>
                            <input type="text" id="PVPurchaseBal" value="0" class="form-control" readonly />
                        </div>
                        <div class="col-md-7 form-group">
                            <label>Adj. Amount</label>
                            <input type="text" id="PVPurchaseBaladjust" onkeypress="return isNumberKey(event);" value="0" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="summary-wallet-block" id="trBVPurchaseBalanace" style="display:none;">
                    <p class="summary-wallet-title">BV Wallet Purchase Balanace</p>
                    <div class="row">
                        <div class="col-md-5 form-group">
                            <label>Aval. Bal.</label>
                            <input type="text" id="BVPurchaseBal" value="0" class="form-control" readonly />
                        </div>
                        <div class="col-md-7 form-group">
                            <label>Adj. Amount</label>
                            <input type="text" id="BVPurchaseBaladjust" onkeypress="return isNumberKey(event);" value="0" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="summary-wallet-block" id="promobalance" style="display:none;">
                    <p class="summary-wallet-title">Promo Wallet</p>
                    <div class="row">
                        <div class="col-md-5 form-group">
                            <label>Aval. Bal.</label>
                            <input type="text" id="promobal" class="form-control" readonly />
                        </div>
                        <div class="col-md-7 form-group">
                            <label>Adj. Amount</label>
                            <input type="text" id="promobaladjust" onkeypress="return isNumberKey(event);" value="0" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="button">
                <input type="hidden" id="isfirstorder" value="@Model.IsFirstOrder" />
                <a href="javascript:void(0)" id="btn" onclick="SaveAddressdetail()" class="btn-pay-now">
                    <i class="fa fa-rupee" aria-hidden="true"></i> Pay Payment
                </a>

                <a href="javascript:void(0)" id="hidbtn" style="display:none;" class="btn-pay-now">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    Wait...
                </a>
            </div>



        </div>
    </div>
</div>
</div>
